{
	"name": "@contexis/wp-react-form",
	"version": "2.2.0",
	"description": "Create forms in the frontend based on JSON Form data",
	"author": "Thomas Gollenia",
	"license": "GPL-2.0-or-later",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"files": [
		"lib",
		"readme.md"
	],
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		},
		"./style.css": "./lib/style.css"
	},
	"bugs": {
		"url": "https://github.com/gollenia/wp-react-form/issues",
		"email": "thomas@gollenia.at"
	},
	"homepage": "https://github.com/gollenia/wp-react-form#readme",
	"scripts": {
		"clean": "rm -rf lib",
		"build": "npm run clean && npm run build:js && npm run build:css && npm run build:types",
		"build:js": "esbuild src/index.ts --bundle --format=cjs --platform=neutral --target=es2020 --sourcemap --outfile=lib/index.js --external:@wordpress/element --external:react --external:react/jsx-runtime --external:react/jsx-dev-runtime",
		"build:css": "esbuild src/style.scss --bundle --loader:.scss=css --outfile=lib/style.css",
		"build:types": "tsc -p tsconfig.types.json",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "biome check biome.json jest.config.ts package.json tsconfig.json tsconfig.jest.json tsconfig.types.json",
		"format": "biome format --write .",
		"test": "jest",
		"postversion": "git push && git push --tags",
		"prepublishOnly": "npm test && npm run build",
		"prepack": "npm run build"
	},
	"dependencies": {
		"@wordpress/components": "^32.6.0",
		"@wordpress/element": "^6.12.0",
		"dompurify": "^3.4.0"
	},
	"peerDependencies": {
		"react": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.0.1",
		"@types/jest": "^29.5.14",
		"@types/react": "^18.3.12",
		"esbuild": "^0.25.11",
		"isomorphic-fetch": "^3.0.0",
		"jest": "^29.7.0",
		"jest-environment-jsdom": "^29.7.0",
		"ts-jest": "^29.2.5",
		"ts-node": "^10.9.2",
		"typescript": "^5.6.3"
	},
	"engines": {
		"node": ">=18"
	},
	"browserslist": [
		"> 1%",
		"last 3 versions",
		"not dead",
		"not ie <= 11"
	]
}
